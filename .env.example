# NodeMind — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Google Gemini API ─────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# Required. The swarm will not run without this.
GEMINI_API_KEY=your_gemini_api_key_here

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/
# Required. Stores all graph nodes and edges.
MONGO_DB_URL=mongodb://localhost:27017

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# Path where ChromaDB persists its vector store on disk.
# Defaults to ./chroma_db if not set.
CHROMA_PERSIST_DIR=./chroma_db
