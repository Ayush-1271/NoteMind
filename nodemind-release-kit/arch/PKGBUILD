pkgname=nodemind
pkgver=0.1.0
pkgrel=1
pkgdesc="Graph memory for multi-agent AI systems"
arch=('x86_64' 'aarch64')
url="https://github.com/gummybearansh/NodeMind"
license=('MIT')
depends=('python' 'python-pip' 'nodejs' 'npm' 'git')
source=("$pkgname-$pkgver.tar.gz::https://github.com/gummybearansh/NodeMind/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('REPLACE_WITH_RELEASE_TARBALL_SHA256')

package() {
  cd "$srcdir/NodeMind-$pkgver"
  python -m pip install . --root="$pkgdir" --no-deps --ignore-installed --prefix=/usr
  install -d "$pkgdir/usr/share/nodemind"
  cp -r frontend "$pkgdir/usr/share/nodemind/frontend"
}
